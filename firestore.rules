
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isDocOwner(data) {
      return isSignedIn() && data.createdBy == request.auth.uid;
    }

    function isAdmin() {
      // Admin user ID with special permissions
      return isSignedIn() && request.auth.uid == 'q4vgkFodzoSaPM1BuNbRI0Wx9YZ2';
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /dailyProgress/{date} {
        allow read, write: if isOwner(userId);
      }
      match /reviewerProgress/{reviewerId} {
        allow read, write: if isOwner(userId);
      }
      match /reviewerBookmarks/{reviewerId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /subjects/{subjectId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /topics/{topicId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reviewers/{reviewerId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isDocOwner(resource.data) || isAdmin();
    }

    match /questions/{questionId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isDocOwner(resource.data) || isAdmin();
    }

    match /pets/{petId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /feedback/{feedbackId} {
      allow create: if true;
      allow read, list: if isAdmin();
    }
  }
}
